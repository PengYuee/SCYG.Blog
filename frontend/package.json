{
  "name": "scyg-blog-admin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --pretty false",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm test:unit && pnpm test:component && pnpm build"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.22",
    "@heroicons/vue": "^2.1.5",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "dompurify": "3.4.12",
    "md-editor-v3": "6.5.3",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.0"
  }
}
